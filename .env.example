# IMEI24 API Credentials (https://imei.org)
IMEI24_API_URL=https://api-client.imei.org/api/dhru
IMEI24_API_KEY=your_imei24_api_key_here

# Supabase (https://supabase.com) - optional for saving check history
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# JWT Secret - change this to a random string in production
JWT_SECRET=change_this_to_a_random_secret_string

# Stripe (optional - for credit payments)
STRIPE_SECRET=sk_test_your_stripe_secret_key_here
