{
  "version": 2,
  "buildCommand": "echo 'No build required for static site'",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/check", "dest": "/imei-check.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.js)", "dest": "/$1" }
  ],
  "env": {
    "IMEI_API_KEY": "@imei_api_key",
    "IMEI_API_URL": "@imei_api_url"
  }
}
